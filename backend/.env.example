# ── Core ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
MONGO_URI=mongodb://localhost:27017
MONGO_DB=identix

# ── Face matching ──────────────────────────────────────────────────────────────
MATCH_THRESHOLD=0.6
FRAME_STRIDE=15

# ── SMTP Email Alerts ──────────────────────────────────────────────────────────
# The system sends an automatic HTML alert to all registered officers
# whenever a CCTV match is detected. Fill in the credentials below.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your-address@gmail.com
#   SMTP_PASS=xxxx-xxxx-xxxx-xxxx   <-- 16-char App Password (not your login password)
#   SMTP_FROM=identix-alerts@gmail.com
#
# Generate a Gmail App Password at:
#   https://myaccount.google.com/apppasswords
#   (requires 2-Step Verification to be enabled)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=identix-alerts@agency.gov
